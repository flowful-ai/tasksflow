{
  "name": "flowtask",
  "version": "0.1.0",
  "private": true,
  "description": "A comprehensive task management platform with GitHub/Slack integrations and AI agent capabilities",
  "author": "FlowTask Team",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.42",
  "scripts": {
    "dev": "turbo run dev --filter=@flowtask/api --filter=@flowtask/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "bun --filter @flowtask/database db:generate",
    "db:migrate": "bun --filter @flowtask/database db:migrate",
    "db:push": "bun --filter @flowtask/database db:push",
    "db:studio": "bun --filter @flowtask/database db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "defu": "^6.1.7",
    "qs": "^6.15.2",
    "ajv": "^8.20.0",
    "axios": "^1.18.0",
    "follow-redirects": "^1.16.0",
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.25",
    "vite": "^6.4.3",
    "better-auth": "^1.6.18",
    "rollup": "^4.62.0",
    "esbuild": "^0.28.1",
    "ip-address": "^10.2.0",
    "kysely": ">=0.28.17",
    "express-rate-limit": "^8.2.2",
    "postcss": "^8.5.10",
    "ws": "^8.20.1",
    "react-router": "^7.14.2",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^2.3.2",
    "turbo": "^2.9.14"
  }
}
